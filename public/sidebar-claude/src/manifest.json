{
  "$schema": "https://json.schemastore.org/chrome-manifest.json",
  "chromium:manifest_version": 3,
  "firefox:manifest_version": 2,
  "version": "0.0.1",
  "name": "Claude AI Sidebar",
  "author": "Cezar Augusto",
  "description": "React sidebar example with Claude AI chat. Adds a sidebar panel with a conversational AI interface powered by the Anthropic SDK.",
  "icons": {
    "16": "images/icon.png",
    "32": "images/icon.png",
    "48": "images/icon.png",
    "64": "images/icon.png",
    "128": "images/icon.png"
  },
  "chromium:action": {
    "default_icon": {
      "16": "images/icon.png",
      "32": "images/icon.png",
      "48": "images/icon.png",
      "64": "images/icon.png",
      "128": "images/icon.png"
    },
    "default_title": "Open Claude AI Sidebar"
  },
  "firefox:browser_action": {
    "default_icon": {
      "16": "images/icon.png",
      "32": "images/icon.png",
      "48": "images/icon.png",
      "64": "images/icon.png",
      "128": "images/icon.png"
    },
    "default_title": "Open Claude AI Sidebar"
  },
  "chromium:side_panel": {
    "default_path": "sidebar/index.html",
    "default_title": "Claude AI Sidebar"
  },
  "firefox:sidebar_action": {
    "default_panel": "sidebar/index.html",
    "default_title": "Claude AI Sidebar"
  },
  "chromium:permissions": ["sidePanel", "storage"],
  "firefox:permissions": ["storage"],
  "background": {
    "chromium:service_worker": "background.ts",
    "firefox:scripts": ["background.ts"]
  }
}

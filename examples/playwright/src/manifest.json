{
  "$schema": "https://json.schemastore.org/chrome-manifest.json",
  "chromium:manifest_version": 3,
  "firefox:manifest_version": 2,
  "version": "1.0.0",
  "name": "Extension.js - Playwright Contract Example",
  "description": "Playwright contract-first example with no-browser and ready.json synchronization.",
  "chromium:action": {
    "default_title": "Open Side Panel"
  },
  "firefox:browser_action": {
    "default_title": "Open Side Panel"
  },
  "chromium:side_panel": {
    "default_path": "sidebar/index.html",
    "default_title": "Playwright Side Panel"
  },
  "firefox:sidebar_action": {
    "default_panel": "sidebar/index.html",
    "default_title": "Playwright Side Panel"
  },
  "chromium:permissions": ["sidePanel"],
  "background": {
    "chromium:service_worker": "background.ts",
    "firefox:scripts": ["background.ts"]
  }
}
